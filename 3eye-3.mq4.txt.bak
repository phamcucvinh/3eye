// [EA 기본 설정]
input string EAConfig = "";                      // 【EA 기본 설정】
input int magicNumber = 123456;                  // 매직 넘버 (EA 식별용)
input int slippage = 20;                         // 허용 슬리피지 (포인트)
input color buyColor = clrYellow;                // 매수 주문 표시 색상
input color sellColor = clrRed;                  // 매도 주문 표시 색상
input color closeColor = clrAqua;                // 청산 주문 표시 색상
input int ordertryMax = 10;                      // 주문 재시도 횟수

// [서브 심볼 설정]
input string SubSymbolConfig = "";               // 【서브 심볼 설정】
input string SubSymbol = "USDJPY";               // 비교할 서브 심볼
input bool UseAccountLimit = false;              // 계좌 제한 사용 여부
input int AccountLimit = 500000;                 // 제한할 계좌 번호

// [가격 스케일링 설정]
